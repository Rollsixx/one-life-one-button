{
  "expo": {
    "name": "one-button-game",
    "slug": "one-button-game",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#03000A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rollsixx.onebuttongame",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#03000A",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.rollsixx.onebuttongame"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "a1679f69-83e0-4788-83ff-c9362b6bf1f6"
      }
    }
  }
}
